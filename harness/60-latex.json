{
  // LaTeX-specific conventions. Float/xref/nbsp discipline comes from
  // the preset; this fragment holds the project's own layout contracts.
  "extends": ["presets/latex-conventions.json"],

  // Map of forbidden raw commands -> required replacement (regex left).
  // Empty for projects without custom macros; example (UI-thesis style):
  //   { "forbid": "\\\\textit\\{", "use": "\\f{}" }
  "latex_commands": [],

  "labels": {
    "severity": "warn",
    "prefixes": ["sec:", "subsec:", "fig:", "tab:", "eq:", "lst:", "app:", "ch:"]
  },

  // FILE-SHAPE CONTRACTS — whole-file structural rules for modular
  // writing. Globs depend on your layout, so declare them per project.
  // Example for a chapters-as-directories layout (root file holds only
  // \chapter + \input; prose lives in per-section sub-files):
  //
  // "file_shapes": [
  //   { "id": "chapter-root", "glob": "src/01-body/bab[0-9].tex",
  //     "allow_only": ["^\\\\chapter", "^\\\\input\\{", "^\\\\label\\{",
  //                    "^\\\\usetikzlibrary"],
  //     "require": ["\\\\chapter\\{", "\\\\input\\{"],
  //     "severity": "error",
  //     "message": "chapter root holds only \\chapter and \\input calls — prose and \\section belong in sub-files" },
  //   { "id": "chapter-leaf", "glob": "src/01-body/bab[0-9]*/*.tex",
  //     "forbid": [
  //       { "pattern": "\\\\chapter\\{",
  //         "message": "\\chapter belongs in the chapter root file" },
  //       { "pattern": "\\\\usetikzlibrary",
  //         "message": "\\usetikzlibrary belongs in the chapter root file" }
  //     ],
  //     "severity": "error" }
  // ]
  "file_shapes": [
    { "id": "chapter-root", "glob": "paper/ch[0-9]*/ch[0-9]*.tex",
      "allow_only": ["^\\\\chapter", "^\\\\input\\{", "^\\\\label\\{",
                     "^\\\\usetikzlibrary"],
      "require": ["\\\\chapter\\{", "\\\\input\\{"],
      "severity": "error",
      "message": "chapter root holds only \\chapter and \\input calls — prose and \\section belong in sub-files" },
    { "id": "section-leaf", "glob": "paper/ch[0-9]*/sec-*/*.tex",
      "forbid": [
        { "pattern": "\\\\chapter\\{",
          "message": "\\chapter belongs in the chapter root file" },
        { "pattern": "\\\\usetikzlibrary",
          "message": "\\usetikzlibrary belongs in the chapter root file" }
      ],
      "severity": "error" }
  ]
}
