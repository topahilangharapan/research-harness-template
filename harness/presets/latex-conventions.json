{
  // PRESET: LaTeX writing conventions — hardcoded structural discipline.
  // Opt-in via "extends" (see 60-latex.json). Non-LaTeX projects are
  // untouched. What this enforces mechanically:
  //   L-FLOAT — every figure/table env has \caption AND \label;
  //             no \includegraphics outside a float
  //   L-XREF  — duplicate \label detection (in-file always; cross-file
  //             in multi-file runs); \ref to unknown labels; float
  //             labels (fig:/tab:/lst:) never referenced in prose
  //             (corpus checks run on --all / pre-commit / CI /
  //              stop gate, where 2+ files are scanned together)
  //   NBSP    — warn on breaking space before \ref (use ~\ref{})
  // Modular file-shape contracts are project-layout-specific: declare
  // them in 60-latex.json under "file_shapes" (example there).

  // MODULAR WRITING — glob-free, so it applies to any file the AI
  // creates, whatever the path:
  //   * a file containing \chapter is a ROOT: \chapter + \input{} only
  //     (no \section, no prose)
  //   * max one \section per file — 2+ means a monolith; each section
  //     lives in its own sub-file (e.g. ch2/sec-related-work.tex)
  "latex_modularity": {
    "enabled": true,
    "chapter_root_only": true,
    "max_sections_per_file": 1,
    // section-as-directory: each section lives in its own folder
    // (paper/ch2/sec-alu/sec-alu.tex) with its figures, listings, and
    // image binaries beside it — delete the folder, the section and
    // all its assets go together:
    "section_in_own_dir": true,
    "severity": "error"
  },

  "latex_floats": {
    "enabled": true,
    "require_caption": true,
    "require_label": true,
    "graphics_in_float": true,
    "severity": "error",
    // \includegraphics targets must EXIST (shelf philosophy: you cannot
    // include an image the user never added):
    "graphics_exist": "error",
    // assets should live beside the section that discusses them
    // (paper/ch2/fig-x.png next to paper/ch2/sec-*.tex):
    "graphics_colocate": "warn",
    // extra roots if the project uses \graphicspath:
    "graphics_paths": []
  },

  "latex_xref": {
    "duplicates": "error",
    "unknown_refs": "error",
    "unreferenced_floats": "error",
    "float_prefixes": ["fig:", "tab:", "lst:"]
  },

  "custom_rules": [
    {
      "id": "LX-NBSP",
      "glob": "*.tex",
      "pattern": "\\s\\\\(?:ref|autoref|cref)\\{",
      "severity": "warn",
      "message": "breaking space before reference — write '~\\ref{...}' so the number cannot wrap to the next line"
    }
  ]
}
